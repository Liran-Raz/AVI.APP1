# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
#
# These are validated by src/server/env.ts at server startup. A missing or
# malformed value fails the server fast with a clear error.

# --- Public (sent to the browser, never secrets) ---

# Supabase project URL — from Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase publishable / anon key — also from Settings → API
# (The publishable key replaces the legacy anon JWT. Safe to expose.)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Used for absolute URLs (OAuth redirects, email links). In production set
# this to the deployed site origin, e.g. https://app.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Email — transactional notifications (feature #12)
# ============================================================
# Optional. Without these, the email service uses a console adapter
# that just logs would-be sends. Set both to activate real delivery
# via Resend (https://resend.com/).
#
# Server-only — never prefix with NEXT_PUBLIC_.

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAIL_FROM="AVI.APP <noreply@your-verified-domain.com>"

# ============================================================
# Encrypted file storage — envelope encryption master key (DEV-032)
# ============================================================
# Optional (the feature is behind the STORAGE_UI flag). The key provider picks
# ONE master-KEK source at runtime — there is no safe no-op, so a misconfigured
# selection fails loud. Server-only — never prefix with NEXT_PUBLIC_.
#
# Production → Google Cloud KMS (managed, me-west1 / Tel-Aviv). A raw env
# master key is refused in a genuine production deployment. The master key
# deliberately lives in a different cloud than the data (Supabase runs on AWS).
# AVI_GCP_KMS_KEY_NAME=projects/<project>/locations/me-west1/keyRings/<ring>/cryptoKeys/<key>
# AVI_GCP_SA_KEY_B64=<base64 of the service-account JSON — Vercel only; Cloud Run uses its ambient identity>
#
# Dev / test / preview → a local base64 32-byte master key (no Google needed).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# AVI_MASTER_KEK_B64=<base64 of 32 random bytes>
